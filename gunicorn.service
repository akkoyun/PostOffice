[Unit]
Description=STF PostOffice V1
After=network.target

[Service]
User=akkoyun
Group=akkoyun
WorkingDirectory=/home/akkoyun/PostOffice/src/
Environment="PATH=/home/akkoyun/PostOffice/PostOffice/bin"
EnvironmentFile=/home/akkoyun/.env
ExecStart=/home/akkoyun/PostOffice/PostOffice/bin/gunicorn -w 5 -k uvicorn.workers.UvicornWorker PostOffice_API.main:PostOffice --bind 0.0.0.0:8000

[Install]
WantedBy=multi-user.target