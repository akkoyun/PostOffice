[Unit]
Description=PostOffice
After=network.target

[Service]
User=akkoyun
Group=akkoyun
WorkingDirectory=/home/akkoyun/PostOffice
Environment="PATH=/home/akkoyun/PostOffice/venv/bin"
EnvironmentFile=/home/akkoyun/PostOffice/.env
ExecStart=/home/akkoyun/PostOffice/venv/bin/gunicorn -w 4 -k uvicorn.workers.UvicornWorker main:app --bind 0.0.0.0:8000

[Install]
WantedBy=multi-user.target